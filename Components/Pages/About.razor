@page "/about"

<section class="about">
    <div class="about-container">

        <h1>About Stratatherm</h1>

        <p class="about-intro">
            We are redefining thermal intelligence through advanced sensing,
            physics-informed AI, and cutting-edge engineering.
        </p>

        <div class="about-grid">

            <div class="about-card">
                <h3>Our Mission</h3>
                <p>
                    To deliver intelligent thermal solutions that improve efficiency,
                    safety, and performance across industries.
                </p>
            </div>

            <div class="about-card">
                <h3>Our Vision</h3>
                <p>
                    A world where thermal systems are fully optimized through
                    data, automation, and intelligent design.
                </p>
            </div>

            <div class="about-card">
                <h3>What We Do</h3>
                <p>
                    We combine advanced sensing, AI modeling, and engineering
                    expertise to solve complex industrial challenges.
                </p>
            </div>

        </div>

    </div>
</section>
